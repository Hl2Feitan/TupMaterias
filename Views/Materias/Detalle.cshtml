@model TupMaterias.Models.Materia

@{
    ViewData["Title"] = Model.Nombre;
}

<h2>@Model.Nombre</h2>
<p class="text-muted">@Model.Descripcion</p>

<div class="card mb-4">
    <div class="card-header"><strong>Profesor a cargo</strong></div>
    <div class="card-body">
        <p class="mb-1"><strong>@Model.Profesor.Nombre</strong></p>
        <p class="text-muted mb-0">@Model.Profesor.Email</p>
    </div>
</div>

<h4>Alumnos inscriptos (@Model.Alumnos.Count)</h4>

@if (Model.Alumnos.Count == 0)
{
    <p class="text-muted">No hay alumnos inscriptos en esta materia.</p>
}
else
{
    <table class="table table-bordered">
        <thead class="table-secondary">
            <tr>
                <th>#</th>
                <th>Legajo</th>
                <th>Nombre</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Alumnos.Count; i++)
            {
                <tr>
                    <td>@(i + 1)</td>
                    <td>@Model.Alumnos[i].Legajo</td>
                    <td>@Model.Alumnos[i].Nombre</td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Index" class="btn btn-secondary">← Volver al listado</a>
